pkgname=cyberlinux-grub-themes
pkgver=0.0.1
pkgrel=1
pkgdesc="GRUB2 themes for cyberlinux"
arch=('any')
url="https://github.com/phR0ze/cyberlinux-grub-themes"
license=('MIT')
depends=('grub')
makedepends=(imagemagick)

source=("git+https://github.com/phR0ze/$pkgname.git#tag=$pkgver")
sha256sums=('SKIP')

package()
{
  cd $srcdir/$pkgname
  msg "Packaging $pkgname..."

  theme=cyberlinux-iso
  cd $theme
  msg2 "Packaging $theme..."
  install -dm755 $pkgdir/usr/share/grub/themes/$theme

  msg2 "Packaging license and docs..."
  install -Dm644 $srcdir/$pkgname/LICENSE -t $pkgdir/usr/share/doc/$pkgname
  install -Dm644 $srcdir/$pkgname/README.md -t $pkgdir/usr/share/doc/$pkgname

	msg2 "Install theme directories..."
  find . -type d -exec install -dm755 $pkgdir/usr/share/grub/themes/$theme/{} \;

	msg2 "Install theme files..."
  find . -type f -exec install -Dm644 {} $pkgdir/usr/share/grub/themes/$theme/{} \;
}

